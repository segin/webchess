# Suppress npm audit and funding messages
audit=false
fund=false

# Do not generate or require a package-lock.json. The lockfile was removed
# because npm 10 (Node 20-23) and npm 11 (Node 24+) resolve puppeteer-core's
# optional proxy-agent subtree differently, breaking `npm ci` across the matrix.
# CI uses `npm install` (no lockfile sync check) instead.
package-lock=false

# Suppress deprecated package warnings for transitive dependencies
# These warnings come from Jest's internal dependencies and cannot be directly fixed
# until Jest updates its own dependencies
loglevel=warn